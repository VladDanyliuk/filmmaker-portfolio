# Sanity CMS
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id_here
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01

# Required for write operations (mutations) — keep server-side only
SANITY_API_TOKEN=your_token_here

# Resend (contact form email)
RESEND_API_KEY=re_xxxxxxxx --- IGNORE ---
ADMIN_EMAIL=your@gmail.com
# FROM_EMAIL defaults to onboarding@resend.dev (Resend sandbox).
# Set to a verified domain address for production: e.g. hello@yourdomain.com
FROM_EMAIL=

# Upstash Redis — durable rate limiting for the contact form (3 req / 15 min per IP).
# Provisioned automatically by the Vercel Marketplace Upstash Redis integration
# (Vercel → Storage → connect Upstash); Vercel injects these in production.
# For local dev, copy KV_REST_API_URL / KV_REST_API_TOKEN from the integration's
# ".env.local" tab (or `vercel env pull`). The other KV_*/REDIS_URL vars Vercel
# adds are unused here. If omitted, the form falls back to a non-durable
# in-memory limiter (dev only).
KV_REST_API_URL=https://your-db.upstash.io
KV_REST_API_TOKEN=your_rest_token_here
